        <mxCell id="n62" value="BARRAMENTO DE EVENTOS DE COMBATE (CombatEvents) — padrão observer:&#xa;tiros, explosões e dano são publicados; IAs, HUD e câmera assinam e reagem" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#101010;strokeColor=#E8720C;strokeWidth=3;fontColor=#FFFFFF;" parent="1" vertex="1">
